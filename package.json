{
  "name": "@harborclient/plugin-api",
  "version": "0.1.1",
  "description": "TypeScript SDK for HarborClient plugin development.",
  "keywords": [
    "harborclient",
    "plugin",
    "typescript",
    "types"
  ],
  "homepage": "https://github.com/harborclient/plugin-api",
  "bugs": {
    "url": "https://github.com/harborclient/plugin-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harborclient/plugin-api.git"
  },
  "license": "MIT",
  "author": {
    "name": "Harbor",
    "email": "harbor@example.com"
  },
  "packageManager": "pnpm@10.17.1",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    },
    "./main": {
      "types": "./dist/main.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "release": "gh workflow run Release --ref main -f release_type=patch",
    "release:patch": "gh workflow run Release --ref main -f release_type=patch",
    "release:minor": "gh workflow run Release --ref main -f release_type=minor",
    "release:major": "gh workflow run Release --ref main -f release_type=major"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.1.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0"
  }
}
