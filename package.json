{
  "name": "@harborclient/sdk",
  "version": "1.0.21",
  "description": "TypeScript SDK for HarborClient plugin development.",
  "keywords": [
    "harborclient",
    "plugin",
    "typescript",
    "types"
  ],
  "homepage": "https://github.com/harborclient/sdk",
  "bugs": {
    "url": "https://github.com/harborclient/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harborclient/sdk.git"
  },
  "license": "MIT",
  "author": {
    "name": "HarborClient",
    "email": "contact@harborclient.com"
  },
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@10.17.1",
  "types": "./dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/runtime/jsx-runtime.d.ts",
      "import": "./dist/runtime/jsx-runtime.js",
      "require": "./dist/runtime/jsx-runtime.js",
      "default": "./dist/runtime/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/runtime/jsx-dev-runtime.d.ts",
      "import": "./dist/runtime/jsx-dev-runtime.js",
      "require": "./dist/runtime/jsx-dev-runtime.js",
      "default": "./dist/runtime/jsx-dev-runtime.js"
    },
    "./jsx-runtime-host": {
      "types": "./dist/runtime/jsx-runtime-host.d.ts",
      "import": "./dist/runtime/jsx-runtime-host.js",
      "require": "./dist/runtime/jsx-runtime-host.js",
      "default": "./dist/runtime/jsx-runtime-host.js"
    },
    "./react": {
      "types": "./dist/runtime/react.d.ts",
      "import": "./dist/runtime/react.js",
      "require": "./dist/runtime/react.js",
      "default": "./dist/runtime/react.js"
    },
    "./react-dom": {
      "types": "./dist/runtime/react-dom.d.ts",
      "import": "./dist/runtime/react-dom.js",
      "require": "./dist/runtime/react-dom.js",
      "default": "./dist/runtime/react-dom.js"
    },
    "./main": {
      "types": "./dist/main.d.ts"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./variables": {
      "types": "./dist/variables/index.d.ts",
      "import": "./dist/variables/index.js",
      "require": "./dist/variables/index.js",
      "default": "./dist/variables/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.js",
      "default": "./dist/storage/index.js"
    },
    "./clipboard": {
      "types": "./dist/clipboard.d.ts",
      "import": "./dist/clipboard.js",
      "require": "./dist/clipboard.js",
      "default": "./dist/clipboard.js"
    },
    "./runtime-utils": {
      "types": "./dist/runtime-utils.d.ts",
      "import": "./dist/runtime-utils.js",
      "require": "./dist/runtime-utils.js",
      "default": "./dist/runtime-utils.js"
    },
    "./store": {
      "types": "./dist/runtime/store.d.ts",
      "import": "./dist/runtime/store.js",
      "require": "./dist/runtime/store.js",
      "default": "./dist/runtime/store.js"
    },
    "./view-host": {
      "types": "./dist/runtime/view-host/index.d.ts",
      "import": "./dist/runtime/view-host/index.js",
      "require": "./dist/runtime/view-host/index.js",
      "default": "./dist/runtime/view-host/index.js"
    },
    "./signing": {
      "types": "./dist/signing/index.d.ts",
      "import": "./dist/signing/index.js",
      "require": "./dist/signing/index.js",
      "default": "./dist/signing/index.js"
    },
    "./build": {
      "types": "./dist/build/index.d.ts",
      "import": "./dist/build/index.js",
      "require": "./dist/build/index.js",
      "default": "./dist/build/index.js"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js",
      "require": "./dist/eslint/index.js",
      "default": "./dist/eslint/index.js"
    },
    "./tsconfig.base.json": "./tsconfig.base.json"
  },
  "bin": {
    "hc-plugin-sign": "./dist/signing/cli-sign.js",
    "hc-plugin-verify": "./dist/signing/cli-verify.js"
  },
  "files": [
    "dist",
    "tsconfig.base.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@faker-js/faker": "^10.5.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@lezer/highlight": "^1.2.3",
    "@uiw/codemirror-themes-all": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "esbuild": "^0.25.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.0"
  },
  "scripts": {
    "prepare": "git config --local core.hooksPath .githooks 2>/dev/null || true",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-runtime.mjs && node scripts/assert-dist-publishable.mjs",
    "attw": "attw --profile esm-only --no-summary",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "clean": "rm -rf dist",
    "dev": "node scripts/copy-runtime.mjs && tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "release": "gh workflow run Release --ref main -f release_type=patch",
    "release:patch": "gh workflow run Release --ref main -f release_type=patch",
    "release:minor": "gh workflow run Release --ref main -f release_type=minor",
    "release:major": "gh workflow run Release --ref main -f release_type=major",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o docs/.vitepress/static/storybook",
    "docs:build": "pnpm docs:build:nav && pnpm build-storybook && vitepress build docs",
    "docs:build:nav": "node scripts/build-docs-nav.mjs && node scripts/assert-docs-slugs.mjs",
    "docs:preview": "pnpm docs:build && vitepress preview docs",
    "docs:serve": "pnpm docs:build:nav && concurrently --kill-others --prefixColors=auto -n nav,vp \"node scripts/watch-docs-nav.mjs\" \"vitepress dev docs\"",
    "plugin:sign": "pnpm build && node dist/signing/cli-sign.js",
    "plugin:verify": "pnpm build && node dist/signing/cli-verify.js"
  },
  "devDependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@jest/globals": "^30.4.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^8.2.2",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.21",
    "debug": "^4.4.3",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "mermaid": "^11.15.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.8.3",
    "vite": "^8.1.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
